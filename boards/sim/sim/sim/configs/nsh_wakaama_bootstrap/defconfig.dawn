CONFIG_DAWN_DEBUG_ERROR=y
CONFIG_DAWN_DEBUG_INFO=y
CONFIG_DAWN_DEBUG_WARN=y
CONFIG_DAWN=y
CONFIG_DAWN_APPS_DAWN=y
CONFIG_DAWN_APPS_DAWN_STACKSIZE=102400
CONFIG_DAWN_APPS_EXAMPLE_DESC_FORMAT_YAML=y
CONFIG_DAWN_APPS_EXAMPLE_DESC_YAML_PATH="../../../descriptors/ntfc/ntfc_wakaama_bootstrap.yaml"
CONFIG_DAWN_PROTO=y
CONFIG_DAWN_PROTO_WAKAAMA=y
CONFIG_DAWN_PROTO_WAKAAMA_ENDPOINT="ntfc-wakaama-bootstrap"
CONFIG_DAWN_PROTO_WAKAAMA_SERVER_HOST="127.0.0.1"
CONFIG_DAWN_PROTO_WAKAAMA_SERVER_PORT=5683
CONFIG_DAWN_PROTO_WAKAAMA_LOCAL_PORT=56830
CONFIG_DAWN_PROTO_WAKAAMA_LIFETIME=60
CONFIG_DAWN_PROTO_WAKAAMA_DEVICE_MODEL_NUMBER="sim"
CONFIG_DAWN_IO_DUMMY=y
CONFIG_DAWN_IO_TRIGGER=y
CONFIG_DAWN_IO_FILE=y
CONFIG_DAWN_IO_SEEKABLE=y
CONFIG_DAWN_IO_NOTIFY=y
CONFIG_DAWN_FAKE_DRIVERS=y
CONFIG_DAWN_FAKE_NET=y
CONFIG_DAWN_FAKE_UID=y
CONFIG_DAWN_FAKE_RESET=y
