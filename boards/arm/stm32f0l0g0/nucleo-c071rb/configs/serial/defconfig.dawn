# CONFIG_DAWN_LIFECYCLE_TEARDOWN is not set
CONFIG_DAWN=y
CONFIG_DAWN_APPS_DAWN=y
CONFIG_DAWN_APPS_DAWN_STACKSIZE=2048
CONFIG_DAWN_APPS_EXAMPLE_DESC_FORMAT_YAML=y
CONFIG_DAWN_APPS_EXAMPLE_DESC_YAML_PATH="../../../descriptors/examples/serial_leds_buttons_demo.yaml"
CONFIG_DAWN_IO_DUMMY=y
CONFIG_DAWN_IO_LEDS=y
CONFIG_DAWN_IO_NOTIFY=y
CONFIG_DAWN_IO_BUTTONS=y
CONFIG_DAWN_PROG=y
CONFIG_DAWN_PROTO=y
CONFIG_DAWN_PROTO_SERIAL=y
